{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "operator"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Alert": {
      "title": "Threat Alert",
      "description": "Security alerts detected by the drone",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["weapon", "suspicious_activity", "unauthorized_entry"] },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "dismissed", "resolved"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["type", "severity", "timestamp", "status"]
    },
    "DroneState": {
      "title": "Drone Telemetry",
      "description": "Real-time status of the aerial robot",
      "type": "object",
      "properties": {
        "droneId": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "patrolling", "returning"] },
        "battery": { "type": "number", "description": "Battery percentage (0-100)" },
        "signal": { "type": "number", "description": "Signal strength (0-100)" },
        "altitude": { "type": "number" },
        "speed": { "type": "number" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      },
      "required": ["droneId", "status", "battery", "signal", "lastUpdate"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user profiles and permissions"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Historical log of security alerts"
    },
    "/droneStatus/{droneId}": {
      "schema": "DroneState",
      "description": "Real-time telemetry for active drones"
    }
  }
}
