rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isOperator() {
      return isSignedIn() && (getUserData().role == 'operator' || getUserData().role == 'admin');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // USER RULES
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Only admins can create or update roles for others. Users can only update their own non-role fields (if we added any).
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == 'operator'); // Basic self-registration as operator if not exists
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    // ALERT RULES
    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isOperator() && isValidId(alertId);
      allow update: if isOperator();
      allow delete: if isAdmin();
    }

    // DRONE STATUS RULES
    match /droneStatus/{droneId} {
      allow read: if isSignedIn();
      allow write: if isOperator();
    }
  }
}
